    title.Outline = true
    title.Visible = false

    local itemIcons = {}
    for i = 1, 15 do
        local icon = Drawing.new("Square")
        icon.Size = Vector2.new(26, 26)
        icon.Position = Vector2.new(70 + ((i - 1) % 5) * 52, 110 + math.floor((i - 1) / 5) * 52)
        icon.Color = Color3.fromRGB(35, 35, 35)
        icon.Filled = true
        icon.Visible = false
        itemIcons[i] = icon
    end

    inventoryCheckerUI = {
