local function applyWeatherPreset(preset)
    if preset == "Clear Day" then
        Config.ClientRain = false
        Config.CustomClouds = false
        Config.CustomSky = false
        Lighting.ClockTime = 14
        Lighting.Brightness = 2
        Lighting.ExposureCompensation = 0
        Lighting.FogEnd = 100000
        
        Toggles.ClientRain:SetValue(false)
        Toggles.CustomClouds:SetValue(false)
        
    elseif preset == "Sunrise" then
        Config.CustomSky = true
        Lighting.ClockTime = 6
        Lighting.Brightness = 1.5
        Lighting.ExposureCompensation = 0.5
        Lighting.Ambient = Color3.fromRGB(255, 150, 100)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 180, 130)
        
        local sky = Lighting:FindFirstChildOfClass("Sky") or Instance.new("Sky", Lighting)
        sky.SunAngularSize = 21
        
    elseif preset == "Aurora Night" then
        Config.CustomSky = true
        Config.CustomAtmosphere = true
        Lighting.ClockTime = 0
        Lighting.Brightness = 0.5
        Lighting.ExposureCompensation = -1
        Lighting.Ambient = Color3.fromRGB(50, 150, 100)
        Lighting.OutdoorAmbient = Color3.fromRGB(30, 100, 80)
        
        local atmos = Lighting:FindFirstChildOfClass("Atmosphere")
        if not atmos then
            atmos = Instance.new("Atmosphere")
            atmos.Parent = Lighting
        end
        atmos.Density = 0.4
        atmos.Offset = 0.5
        atmos.Color = Color3.fromRGB(100, 255, 150)
        atmos.Decay = Color3.fromRGB(50, 150, 100)
        atmos.Glare = 0.5
        atmos.Haze = 2
        
    elseif preset == "Heavy Storm" then
        Config.ClientRain = true
        Config.RainIntensity = 180
        Config.RainWindAngle = 25
        Config.RainWindStrength = 3
        Config.CustomClouds = true
        Config.CloudDensity = 0.8
        Config.CloudColor = Color3.fromRGB(60, 60, 70)
        Config.CloudCover = 0.9
        Config.Lightning = true
        
        Lighting.ClockTime = 15
