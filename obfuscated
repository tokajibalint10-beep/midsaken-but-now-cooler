local function stopInventoryViewer()
    clearResources("INVENTORY_VIEWER")
    if inventoryCheckerUI.bg then
        inventoryCheckerUI.bg.Visible = false
        inventoryCheckerUI.title.Visible = false
        for _, obj in ipairs(inventoryCheckerUI.itemIcons or {}) do
            obj.Visible = false
        end
    end
end

local function updateInventoryViewer()
    if not Config.InventoryViewer then
        stopInventoryViewer()
        return
    end
    if not inventoryCheckerUI.bg then
        createInventoryViewerUI()
    end

    local target
    local closestDist = Config.FOVRadius or math.huge
    local mousePos = UIS:GetMouseLocation()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local scr, on = Cam:WorldToViewportPoint(hrp.Position)
                if on then
                    local dist = (Vector2.new(scr.X, scr.Y) - mousePos).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        target = plr
                    end
                end
            end
        end
    end
    if not target then
        stopInventoryViewer()
        return
    end

    local playersFolder = ReplicatedStorage:FindFirstChild("Players")
    local playerFolder = playersFolder and playersFolder:FindFirstChild(target.Name)
    local inventory = playerFolder and playerFolder:FindFirstChild("Inventory")
    if not inventory then
        stopInventoryViewer()
        return
    end

    local items = inventory:GetChildren()
    inventoryCheckerUI.bg.Visible = true
    inventoryCheckerUI.title.Text = (target.DisplayName or target.Name) .. " (@" .. target.Name .. ")"
    inventoryCheckerUI.title.Visible = true
    for i = 1, 15 do
        local icon = inventoryCheckerUI.itemIcons[i]
        local item = items[i]
        if item and item:IsA("ObjectValue") and item.Value then
            local value = item.Value
            local iconImage = value:FindFirstChild("ItemProperties") and value.ItemProperties:FindFirstChild("ItemIcon")
            if iconImage and iconImage:IsA("ImageLabel") then
                icon.Color = Color3.fromRGB(35, 35, 35)
            end
            icon.Visible = true
        else
            icon.Visible = false
        end
    end
end

local function startInventoryViewer()
    clearResources("INVENTORY_VIEWER")
    addResource("INVENTORY_VIEWER", RunService.RenderStepped:Connect(updateInventoryViewer))
end

