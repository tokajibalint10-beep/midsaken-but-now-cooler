    cleanupESPForPlayer(plr)
    addResource("ESP", plr.CharacterAdded:Connect(function(char)
        setupCharacterESP(plr, char)
    end))
    if plr.Character then
        task.defer(function()
            setupCharacterESP(plr, plr.Character)
        end)
    end
end

