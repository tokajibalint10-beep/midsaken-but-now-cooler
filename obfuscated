local function getClosestAIToCrosshair(currentClosest, currentDist, maxRadius)
    if not Config.AimAtAI then
        return currentClosest, currentDist
    end
    local aiZones = Workspace:FindFirstChild("AiZones")
    if not aiZones then
        return currentClosest, currentDist
    end
    local mousePos = UIS:GetMouseLocation()
    for _,zone in ipairs(aiZones:GetChildren()) do
        if zone:IsA("Folder") then
            for _,m in ipairs(zone:GetChildren()) do
                if m:IsA("Model") then
                    local part = m:FindFirstChild("HumanoidRootPart")
                        or m:FindFirstChild("Head")
                        or m.PrimaryPart
                    if part then
                        local scr, on = Cam:WorldToViewportPoint(part.Position)
                        if on then
                            local d = (Vector2.new(scr.X, scr.Y) - mousePos).Magnitude
                            if d < maxRadius and d < currentDist then
                                currentClosest, currentDist = part, d
                            end
                        end
                    end
                end
            end
        end
    end
    return currentClosest, currentDist
end

local lockedTarget = nil
local lockedTargetPlayer = nil

local function getTarget()
    if lockedTarget and lockedTarget.Parent then
        return lockedTarget
    end
    
    local closest, cDist = nil, math.huge
    local mousePos = UIS:GetMouseLocation()
    local maxRadius = Config.FOVRadius
    if not maxRadius or maxRadius <= 0 then
        maxRadius = math.huge
    end
    local players = Players:GetPlayers()
    for i = 1,#players do
        local plr = players[i]
        if plr ~= LP and plr.Character and not isFriend(plr) and not isWhitelisted(plr) then
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local tp = plr.Character:FindFirstChild(Config.LockPart)
                    or plr.Character:FindFirstChild("HumanoidRootPart")
                if tp then
                    local scr, on = Cam:WorldToViewportPoint(tp.Position)
                    if on then
                        local d = (Vector2.new(scr.X, scr.Y) - mousePos).Magnitude
                        if d < maxRadius and d < cDist then
                            closest, cDist = tp, d
                            lockedTargetPlayer = plr
                        end
                    end
                end
            end
        end
    end
    closest, cDist = getClosestAIToCrosshair(closest, cDist, maxRadius)
    return closest
