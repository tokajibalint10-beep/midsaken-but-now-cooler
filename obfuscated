    Text = 'Add to Whitelist',
    Func = function()
        local name = Options.WhitelistPlayerInput.Value
        if name and name ~= '' then
            local alreadyExists = false
            for _,n in ipairs(Config.Whitelist) do
                if n == name then
                    alreadyExists = true
                    break
                end
            end
            if not alreadyExists then
                table.insert(Config.Whitelist, name)
                Library:Notify('Added ' .. name .. ' to whitelist')
            else
                Library:Notify(name .. ' is already whitelisted')
            end
            Options.WhitelistPlayerInput:SetValue('')
        end
    end,
    DoubleClick = false,
})

