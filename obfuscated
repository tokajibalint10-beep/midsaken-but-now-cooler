}

local downloadedSounds = {}

local function downloadSound(url)
    if downloadedSounds[url] then
        return downloadedSounds[url]
    end
    
    local success, result = pcall(function()
        Library:Notify('Downloading sound...')
        local response = game:HttpGetAsync(url)
        local filename = "TFG_" .. tostring(tick()):gsub("%.", "_") .. ".mp3"
        
        if not isfolder("TerhesFerfiGaming") then
            makefolder("TerhesFerfiGaming")
        end
        
        local filepath = "TerhesFerfiGaming/" .. filename
        writefile(filepath, response)
        
        local assetFunc = getcustomasset or getsynasset or function(path)
            return "file:///" .. path
        end
        
        local asset = assetFunc(filepath)
        downloadedSounds[url] = asset
        Library:Notify('Sound downloaded!')
        return asset
    end)
    
    if success and result then
        return result
    else
        Library:Notify('Failed to download sound: ' .. tostring(result))
        return nil
    end
end

local function applyHitSound()
    local hitMarkersFolder = ReplicatedStorage:FindFirstChild("SFX")
    if hitMarkersFolder then
        hitMarkersFolder = hitMarkersFolder:FindFirstChild("Hits")
        if hitMarkersFolder then
            hitMarkersFolder = hitMarkersFolder:FindFirstChild("HitMarkers")
            if hitMarkersFolder then
                local soundUrl = hitSounds[Config.HitSound]
                if soundUrl then
                    local soundAsset = downloadSound(soundUrl)
                    if soundAsset then
                        for _, sound in ipairs(hitMarkersFolder:GetChildren()) do
                            if sound:IsA("Sound") then
                                sound.SoundId = soundAsset
                            end
                        end
                    end
                end
            end
        end
    end
end

local function applyGunSound()
    local itemsListModels = ReplicatedStorage:FindFirstChild("ItemsListModels")
    if not itemsListModels then return end
    
    local soundUrl = gunSounds[Config.GunSound]
    if not soundUrl then return end
    
    local soundAsset = downloadSound(soundUrl)
    if not soundAsset then return end
    
    for _, gunModel in ipairs(itemsListModels:GetChildren()) do
        local itemRoot = gunModel:FindFirstChild("ItemRoot")
        if itemRoot then
            local sounds = itemRoot:FindFirstChild("Sounds")
            if sounds then
                local fireSound = sounds:FindFirstChild("FireSound")
                if fireSound and fireSound:IsA("Sound") then
                    fireSound.SoundId = soundAsset
                end
            end
        end
    end
end

local function applyGasMaskBreathing(state)
    local sfx = ReplicatedStorage:FindFirstChild("SFX")
    if not sfx then return end
    for _, obj in ipairs(sfx:GetDescendants()) do
        if obj:IsA("Sound") and (obj.Name:lower():find("breath") or obj.Name:lower():find("gas")) then
            obj.Volume = state and 0 or 1
        end
    end
end

