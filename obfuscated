local function setupSilentAim()
    if silentAimSetup then return true end
    
    local success, bulletModule = pcall(require, ReplicatedStorage.Modules.FPS.Bullet)
    if not success or not bulletModule then
        Library:Notify("Could not load Silent Aim - Bullet module not found")
        return false
    end
    
    oldBullet = hookfunction(bulletModule.CreateBullet, function(idk, model, model2, model3, aimPart, idk2, ammoType, tick, recoilPattern)
        if not Config.AimbotEnabled or Config.AimbotMode ~= "Silent Aim" then
            return oldBullet(idk, model, model2, model3, aimPart, idk2, ammoType, tick, recoilPattern)
        end
        
        local target = getSilentAimTarget(model, model2, model3, aimPart)
        if target then
            lockedTarget = target
            lockedTargetPlayer = Players:GetPlayerFromCharacter(target.Parent)
            local ammoTypesFolder = ReplicatedStorage:FindFirstChild("AmmoTypes")
            if not ammoTypesFolder then
                return oldBullet(idk, model, model2, model3, aimPart, idk2, ammoType, tick, recoilPattern)
            end
            
            local bullet = ammoTypesFolder:FindFirstChild(ammoType)
            if bullet then
                local acceleration = bullet:GetAttribute("ProjectileDrop") or bullet:GetAttribute("PorjectileDrop")
                local projectileSpeed = bullet:GetAttribute("MuzzleVelocity") 
                    or bullet:GetAttribute("ProjectileSpeed")
                    or bullet:GetAttribute("BulletSpeed")
                
                if not projectileSpeed or projectileSpeed <= 0 then
                    return oldBullet(idk, model, model2, model3, aimPart, idk2, ammoType, tick, recoilPattern)
                end
                
                pcall(function()
                    bullet:SetAttribute("Drag", 0)
                end)
                
                local aimOrigin = aimPart.Position
                local distMeters = (target.Position - aimOrigin).Magnitude * 0.28
                local leadFactor = math.clamp((distMeters - 35) / 115, 0, 1)
                local targetVelocity = target.AssemblyLinearVelocity or target.Velocity or Vector3.zero
                local parent = target.Parent
                if parent then
                    local root = parent:FindFirstChild("HumanoidRootPart")
                    if root then
                        targetVelocity = root.AssemblyLinearVelocity or root.Velocity or targetVelocity
                    end
                end
                local timeToTarget = (target.Position - aimOrigin).Magnitude / projectileSpeed
                local predictedPos = target.Position + (targetVelocity * timeToTarget * (1 + leadFactor * 0.35))
                local vertical = projectileDrop(aimOrigin, predictedPos, projectileSpeed, acceleration)
                if distMeters > 80 then
                    local compensation = 1 + math.clamp((distMeters - 80) * 0.002, 0, 0.18)
                    vertical = vertical * compensation
                end
                
                local new = {
                    ["CFrame"] = CFrame.new(aimOrigin, predictedPos + vertical)
                }
                
                return oldBullet(idk, model, model2, model3, new, idk2, ammoType, tick, recoilPattern)
            end
        end
        
        return oldBullet(idk, model, model2, model3, aimPart, idk2, ammoType, tick, recoilPattern)
    end)
    
    silentAimSetup = true
    return true
end

