local rainParts = {}
local rainUpdateTick = 0

local function startClientRain()
    clearResources("CLIENT_RAIN")
    
    for _, part in ipairs(rainParts) do
        pcall(function() part:Destroy() end)
    end
    rainParts = {}
    
    local rainFolder = Instance.new("Folder")
    rainFolder.Name = "ClientRain"
    rainFolder.Parent = Workspace
    
    addResource("CLIENT_RAIN", RunService.Heartbeat:Connect(function(dt)
        if not Config.ClientRain then
            for _, part in ipairs(rainParts) do
                if part and part.Parent then
                    part.Transparency = 1
                end
            end
            return
        end
        
        rainUpdateTick = rainUpdateTick + dt
        if rainUpdateTick < 0.033 then
            return
        end
        rainUpdateTick = 0
        
        local camPos = Cam.CFrame.Position
        local targetCount = math.min(Config.RainIntensity, 200)
        
        while #rainParts < targetCount do
            local drop = Instance.new("Part")
            drop.Size = Vector3.new(0.05, math.random(20, 40) / 100, 0.05)
            drop.Material = Enum.Material.Neon
            drop.Color = Color3.fromRGB(200, 220, 255)
            drop.Transparency = math.random(20, 40) / 100
            drop.Anchored = true
            drop.CanCollide = false
            drop.CastShadow = false
            drop.Name = "RainDrop"
            
            local randomX = math.random(-80, 80)
            local randomZ = math.random(-80, 80)
            local startY = math.random(30, 50)
            
            local windAngle = Config.RainWindAngle or 0
            local windStrength = Config.RainWindStrength or 0
            
            drop.CFrame = CFrame.new(camPos + Vector3.new(randomX, startY, randomZ)) 
                * CFrame.Angles(math.rad(windAngle), 0, 0)
            
            drop:SetAttribute("Speed", math.random(15, 25) / 10)
            drop:SetAttribute("WindOffset", windStrength)
            drop.Parent = rainFolder
            
            rainParts[#rainParts + 1] = drop
        end
        
        while #rainParts > targetCount do
            local drop = rainParts[#rainParts]
            if drop then
                pcall(function() drop:Destroy() end)
            end
            table.remove(rainParts, #rainParts)
        end
        
        local windAngle = Config.RainWindAngle or 0
        local windStrength = Config.RainWindStrength or 0
        
        for i = 1, #rainParts do
            local drop = rainParts[i]
            if drop and drop.Parent then
                drop.Transparency = math.random(20, 40) / 100
                
                local speed = drop:GetAttribute("Speed") or 2
                local windOffset = drop:GetAttribute("WindOffset") or 0
                
                local pos = drop.Position
                local windX = math.sin(math.rad(windAngle)) * windOffset * 0.5
                local windZ = math.cos(math.rad(windAngle)) * windOffset * 0.5
                
                drop.CFrame = CFrame.new(
                    pos.X + windX,
                    pos.Y - speed,
                    pos.Z + windZ
                ) * CFrame.Angles(math.rad(windAngle), 0, 0)
                
                if pos.Y < camPos.Y - 20 then
                    local randomX = math.random(-80, 80)
                    local randomZ = math.random(-80, 80)
                    local startY = math.random(30, 50)
                    drop.CFrame = CFrame.new(camPos + Vector3.new(randomX, startY, randomZ))
                        * CFrame.Angles(math.rad(windAngle), 0, 0)
                    drop:SetAttribute("Speed", math.random(15, 25) / 10)
                end
            end
        end
    end))
    
    addResource("CLIENT_RAIN", function()
        for _, part in ipairs(rainParts) do
            pcall(function() part:Destroy() end)
        end
        rainParts = {}
        if rainFolder and rainFolder.Parent then
            rainFolder:Destroy()
        end
    end)
end

local function stopClientRain()
    clearResources("CLIENT_RAIN")
    for _, part in ipairs(rainParts) do
        pcall(function() part:Destroy() end)
    end
    rainParts = {}
end

