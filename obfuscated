local function applyXray(state)
    local zones = Workspace:FindFirstChild("AiZones")
    local roots = {
        Workspace:FindFirstChild("Map"),
        Workspace:FindFirstChild("Environment"),
        Workspace:FindFirstChild("Buildings"),
        Workspace:FindFirstChild("Props"),
    }
    local targets = {}
    for _, root in ipairs(roots) do
        if root then
            for _, part in ipairs(root:GetDescendants()) do
                if part:IsA("BasePart") then
                    targets[#targets + 1] = part
                end
            end
        end
    end
    if #targets == 0 then
        for _, part in ipairs(Workspace:GetChildren()) do
            if part:IsA("BasePart") then
                targets[#targets + 1] = part
            end
        end
    end
    for _, part in ipairs(targets) do
        if part:IsA("BasePart") and not (zones and part:IsDescendantOf(zones)) then
            if state then
                if not part:FindFirstChild("XrayOriginalTransparency") then
                    local nv = Instance.new("NumberValue")
                    nv.Name = "XrayOriginalTransparency"
                    nv.Value = part.Transparency
                    nv.Parent = part
                end
                part.Transparency = 0.5
            else
                local nv = part:FindFirstChild("XrayOriginalTransparency")
                if nv then
                    part.Transparency = nv.Value
                    nv:Destroy()
                end
            end
        end
    end
end

