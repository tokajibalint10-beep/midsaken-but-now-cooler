local function applyViewmodelChanger()
    local camModel = Workspace:FindFirstChild("Camera")
    if not camModel then return end
    local viewModel = camModel:FindFirstChild("ViewModel")
    if not viewModel then return end
    if not Config.ViewmodelChanger then
        if viewmodelModelCache then
            for part, original in pairs(viewmodelCache) do
                if part and part.Parent then
                    part.Transparency = original.Transparency
                    part.Color = original.Color
                end
            end
            viewmodelCache = {}
            viewmodelModelCache = nil
        end
        return
    end
    if viewmodelModelCache ~= viewModel then
        viewmodelCache = {}
        viewmodelModelCache = {
            model = viewModel,
            pivot = viewModel:GetPivot(),
        }
    end
    local base = viewmodelModelCache and viewmodelModelCache.pivot
    if base then
        pcall(function()
            viewModel:PivotTo(base * CFrame.new(Config.ViewmodelOffset))
        end)
    end
    for _, obj in ipairs(viewModel:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
            if not viewmodelCache[obj] then
                viewmodelCache[obj] = {Transparency = obj.Transparency, Color = obj.Color}
            end
            local original = viewmodelCache[obj]
            obj.Transparency = math.clamp(Config.ViewmodelTransparency, 0, 1)
            obj.Color = Config.ViewmodelColor
        end
    end
end

local function applyAntiAim(dt)
    local root = getRootPart()
    if not root or not Config.AntiAim then return end
    antiAimAccumulator += dt * Config.AntiAimSpeed
    if Config.AntiAimMode == "Spin" then
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, antiAimAccumulator, 0)
    elseif Config.AntiAimMode == "Jitter" then
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(math.random(-Config.AntiAimJitter, Config.AntiAimJitter)), 0)
    else
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(180), 0)
    end
end

