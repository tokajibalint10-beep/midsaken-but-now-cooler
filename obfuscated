local function toggleInstantMosin(state)
    recoilCache = recoilCache or {}
    local ammoTypes = ReplicatedStorage:FindFirstChild("AmmoTypes")
    if not ammoTypes then return end
    if state then
        for _, ammo in ipairs(ammoTypes:GetChildren()) do
            if recoilCache[ammo] == nil then
                recoilCache[ammo] = ammo:GetAttribute("RecoilStrength")
            end
            ammo:SetAttribute("RecoilStrength", 0)
        end
    else
        for _, ammo in ipairs(ammoTypes:GetChildren()) do
            if recoilCache[ammo] ~= nil then
                ammo:SetAttribute("RecoilStrength", recoilCache[ammo])
            end
        end
    end
end

local function NoSpread(state)
    local ammoTypes = ReplicatedStorage:FindFirstChild("AmmoTypes")
    if not ammoTypes then return end
    if state then
        for _, ammo in ipairs(ammoTypes:GetChildren()) do
            if not spreadCache[ammo] then
                spreadCache[ammo] = {
                    AccuracyDeviation = ammo:GetAttribute("AccuracyDeviation"),
                    ProjectileDrop = ammo:GetAttribute("ProjectileDrop"),
                }
            end
            if ammo:GetAttribute("AccuracyDeviation") ~= nil then
                ammo:SetAttribute("AccuracyDeviation", 0)
            end
            ammo:SetAttribute("ProjectileDrop", 0)
        end
    else
        for _, ammo in ipairs(ammoTypes:GetChildren()) do
            local cache = spreadCache[ammo]
            if cache then
                if cache.AccuracyDeviation ~= nil then
                    ammo:SetAttribute("AccuracyDeviation", cache.AccuracyDeviation)
                end
                ammo:SetAttribute("ProjectileDrop", cache.ProjectileDrop)
            end
        end
    end
end

