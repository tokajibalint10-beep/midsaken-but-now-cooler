                    lastLightning = now
                    
                    lightningState.originalBrightness = Lighting.Brightness
                    lightningState.originalAmbient = Lighting.Ambient
                    
                    Lighting.Brightness = 5
                    Lighting.Ambient = Color3.fromRGB(255, 255, 255)
                    
                    task.wait(0.1)
                    resetLightningState()
                    
                    task.wait(0.05)
                    Lighting.Brightness = 4
                    Lighting.Ambient = Color3.fromRGB(240, 240, 255)
                    
                    task.wait(0.08)
                    resetLightningState()
                end
            end))
        else
            clearResources("LIGHTNING")
            resetLightningState()
        end
    end
})

