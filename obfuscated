local isReloading = false
local reloadStartTime = 0
local reloadDuration = 2
local currentReloadTrack = nil
local animationWeights = {}
local idleTrack = nil

local function disableViewmodelAnimations()
    clearResources("VIEWMODEL_ANIM")
    
    ensureReloadIndicator()
    
    addResource("VIEWMODEL_ANIM", RunService.RenderStepped:Connect(function()
        if not Config.DisableViewmodelAnims then
            hideReloadIndicator()
            isReloading = false
            currentReloadTrack = nil
            idleTrack = nil
            for track, originalWeight in pairs(animationWeights) do
                if track and track.IsPlaying then
                    pcall(function()
                        track:AdjustWeight(originalWeight, 0)
                    end)
                end
            end
            animationWeights = {}
            return
        end
        
        local camModel = Workspace:FindFirstChild("Camera")
        if not camModel then return end
        
        local viewModel = camModel:FindFirstChild("ViewModel")
        if not viewModel then return end
        
        local humanoid = viewModel:FindFirstChildOfClass("Humanoid")
        if not humanoid then return end
        
        local animator = humanoid:FindFirstChildOfClass("Animator")
        if animator then
            local tracks = animator:GetPlayingAnimationTracks()
            local reloadTrackFound = false
            
            for _, track in pairs(tracks) do
                if not track or not track.Animation then continue end
                
                local animName = track.Animation.Name:lower()
                local animId = track.Animation.AnimationId:lower()
                
                if not animationWeights[track] then
                    animationWeights[track] = track.WeightCurrent > 0 and track.WeightCurrent or 1
                end
                
                if animName:find("idle") then
                    idleTrack = track
                    pcall(function()
                        track:AdjustWeight(10, 0)
                    end)
                    continue
                end
                
                if animName:find("reload") or animId:find("reload") then
                    reloadTrackFound = true
                    if currentReloadTrack ~= track then
                        currentReloadTrack = track
                        isReloading = true
                        reloadStartTime = tick()
                        reloadDuration = track.Length or 2
                    end
                end
                
                pcall(function()
                    track:AdjustWeight(0, 0)
                end)
            end
            
            if idleTrack and idleTrack.IsPlaying then
                pcall(function()
                    idleTrack:AdjustWeight(10, 0)
                end)
            end
            
            if not reloadTrackFound and isReloading then
                isReloading = false
                currentReloadTrack = nil
                hideReloadIndicator()
            end
        end
        
        if isReloading then
            local elapsed = tick() - reloadStartTime
            local progress = math.clamp(elapsed / reloadDuration, 0, 1)
            
            local vp = Cam.ViewportSize
            local centerX = vp.X / 2
            local centerY = vp.Y / 2
            
            reloadIndicator.bg.Position = Vector2.new(centerX - 100, centerY + 40)
            reloadIndicator.bg.Visible = true
            
            reloadIndicator.text.Position = Vector2.new(centerX, centerY + 55)
            reloadIndicator.text.Visible = true
            
            reloadIndicator.barBg.Position = Vector2.new(centerX - 90, centerY + 72)
            reloadIndicator.barBg.Visible = true
            
            local barWidth = 180 * progress
            reloadIndicator.barFg.Size = Vector2.new(barWidth, 10)
            reloadIndicator.barFg.Position = Vector2.new(centerX - 90, centerY + 72)
            reloadIndicator.barFg.Visible = true
            
            if progress < 0.33 then
                reloadIndicator.barFg.Color = Color3.fromRGB(255, 100, 100)
            elseif progress < 0.66 then
                reloadIndicator.barFg.Color = Color3.fromRGB(255, 200, 100)
            else
                reloadIndicator.barFg.Color = Color3.fromRGB(100, 255, 100)
            end
            
            if progress >= 1 then
                isReloading = false
                currentReloadTrack = nil
                hideReloadIndicator()
            end
        else
            hideReloadIndicator()
        end
    end))
end

local function enableViewmodelAnimations()
    clearResources("VIEWMODEL_ANIM")
    hideReloadIndicator()
    isReloading = false
    currentReloadTrack = nil
    idleTrack = nil
    for track, originalWeight in pairs(animationWeights) do
        if track and track.IsPlaying then
            pcall(function()
                track:AdjustWeight(originalWeight, 0)
            end)
        end
    end
    animationWeights = {}
end

local function getCurrentWeaponDrop()
    local char = LP.Character
    if not char then return nil, nil end
    local holding = char:FindFirstChild("Holding")
    if not holding or not holding:IsA("ObjectValue") or not holding.Value then
        return nil, nil
    end
    local weaponName
    if typeof(holding.Value) == "Instance" then
        weaponName = holding.Value.Name
    else
        weaponName = tostring(holding.Value)
    end
    local ammoTypesFolder = ReplicatedStorage:FindFirstChild("AmmoTypes")
    local itemsList = ReplicatedStorage:FindFirstChild("ItemsList")
    if not ammoTypesFolder or not itemsList then return nil, nil end
    local weaponInstance = itemsList:FindFirstChild(weaponName)
    if not weaponInstance then return nil, nil end
    local itemPropsFolder = weaponInstance:FindFirstChild("ItemProperties")
    local sources = {weaponInstance}
    if itemPropsFolder then
        sources[#sources+1] = itemPropsFolder
    end
    local selectedDrop, selectedSpeed
    for _,ammoFolder in ipairs(ammoTypesFolder:GetChildren()) do
        if ammoFolder:IsA("Folder") then
            local ammoName = ammoFolder.Name
            local matched = false
            for _,src in ipairs(sources) do
                if src:GetAttribute(ammoName) ~= nil then
                    matched = true
                    break
                end
            end
            if matched then
                local dropVal = ammoFolder:GetAttribute("PorjectileDrop") or ammoFolder:GetAttribute("ProjectileDrop")
                local speedVal = ammoFolder:GetAttribute("ProjectileSpeed")
                    or ammoFolder:GetAttribute("MuzzleVelocity")
                    or ammoFolder:GetAttribute("BulletSpeed")
                    or ammoFolder:GetAttribute("ProjectileVelocity")
                if typeof(dropVal) == "number" then
                    selectedDrop = dropVal
                end
                if typeof(speedVal) == "number" then
                    selectedSpeed = speedVal
                end
                break
            end
        end
    end
    return selectedDrop, selectedSpeed
end

local function isVisible(origin, target, ...)
