local statsBox = { lines=nil, text=nil, bg=nil }

local function ensureStatsBox()
    if statsBox.lines and statsBox.text and statsBox.bg then return end
    local box = {}
    for i = 1,4 do
        local l = NewLine()
        l.Thickness = 2
        box[i] = l
    end
    local t = Drawing.new("Text")
    t.Size = 16
    t.Center = false
    t.Visible = false
    t.Color = Color3.new(1,1,1)
    t.Outline = true
    t.OutlineColor = Color3.new(0,0,0)
    local bg = Drawing.new("Square")
    bg.Visible = false
    bg.Filled = true
    bg.Color = Color3.fromRGB(20,20,20)
    bg.Transparency = 0.85
    statsBox.lines, statsBox.text, statsBox.bg = box, t, bg
end

local function hideStatsBox()
    if statsBox.lines then
        for _,l in ipairs(statsBox.lines) do
            l.Visible = false
        end
    end
    if statsBox.text then
        statsBox.text.Visible = false
    end
    if statsBox.bg then
        statsBox.bg.Visible = false
    end
end

local function toggleStatsBox(state)
    clearResources("STATSBOX")
    if not state then
        hideStatsBox()
        return
    end
    ensureStatsBox()
    local updateInterval = 0.5
    local nextUpdate = 0
    local frameCount = 0
    local accTime = 0
    local finalText = ""
    addResource("STATSBOX", RunService.RenderStepped:Connect(function(dt)
        if not Config.DrawStatsBox then
            hideStatsBox()
            return
        end
        frameCount += 1
        accTime += dt
        local now = os.clock()
        if now >= nextUpdate then
            local fps = frameCount / math.max(accTime, 1e-6)
            local ping = 0
            local ok,stat = pcall(function()
                return Stats.Network.ServerStatsItem["Data Ping"]
            end)
            if ok and stat and stat.GetValueString then
                local s = stat:GetValueString() or "0 ms"
                ping = tonumber(string.match(s, "(%d+)") or 0) or 0
            end
            finalText = ("FPS: %d | Ping: %d ms | Players: %d/%d"):format(
                fps,
                ping,
                #Players:GetPlayers(),
                Players.MaxPlayers or 0
            )
            frameCount = 0
            accTime = 0
            nextUpdate = now + updateInterval
        end
        local t = statsBox.text
        t.Text = finalText
        t.Position = Vector2.new(30,40)
        t.Visible = true
        local w = math.max(180, #finalText * 7 + 12)
        local h = 36
        statsBox.bg.Position = Vector2.new(20,30)
        statsBox.bg.Size = Vector2.new(w,h)
        statsBox.bg.Visible = true
        local col = Color3.fromHSV((os.clock()*0.5) % 1, 1, 1)
        local x1,y1 = 20,30
        local x2,y2 = x1 + w, y1 + h
        local b = statsBox.lines
        b[1].From, b[1].To = Vector2.new(x1,y1), Vector2.new(x2,y1)
        b[2].From, b[2].To = Vector2.new(x2,y1), Vector2.new(x2,y2)
        b[3].From, b[3].To = Vector2.new(x2,y2), Vector2.new(x1,y2)
        b[4].From, b[4].To = Vector2.new(x1,y2), Vector2.new(x1,y1)
        for _,l in ipairs(b) do
            l.Visible = true
            l.Color = col
        end
    end))
end

local function getEquippedGun()
    local char = LP.Character
    if not char then return nil end
    local holding = char:FindFirstChild("Holding")
    if not holding or not holding.Value then return nil end
    local gunName = tostring(holding.Value)
    local itemsList = ReplicatedStorage:FindFirstChild("ItemsList")
    if not itemsList then return nil end
    return itemsList:FindFirstChild(gunName)
end

local function getWeaponDisplayName(gun)
    if not gun then return nil end
    local n = gun.Name
    n = n:gsub("Front","")
    n = n:gsub("Handle","")
    return n
end

local function getAllSkinsForGun(gun)
    local skinsFolder = ReplicatedStorage:FindFirstChild("Skins")
    if not skinsFolder or not gun then return {} end
    local base = gun.Name
    local weaponBase = base:gsub("Front",""):gsub("Handle","")
    local out = {}
    for _,f in ipairs(skinsFolder:GetChildren()) do
        if f:IsA("Folder") and f.Name:find(weaponBase) then
            for _,skin in ipairs(f:GetChildren()) do
                if skin:IsA("Folder") then
                    out[#out+1] = skin.Name
                end
            end
        end
    end
    return out
end

local function getAllSkins()
    local skinsFolder = ReplicatedStorage:FindFirstChild("Skins")
    if not skinsFolder then return {} end
    local out = {}
    for _, folder in ipairs(skinsFolder:GetChildren()) do
        for _, skin in ipairs(folder:GetChildren()) do
            if skin:IsA("Folder") then
                out[#out + 1] = skin.Name
            end
        end
    end
    table.sort(out)
    return out
end

local function getSkinTexture(skinName)
    local skinsFolder = ReplicatedStorage:FindFirstChild("Skins")
    if not skinsFolder then return nil end
    for _, folder in ipairs(skinsFolder:GetChildren()) do
        local skin = folder:FindFirstChild(skinName)
        if skin and skin:FindFirstChild("Textures") and skin.Textures:FindFirstChild("Base") then
            return skin.Textures.Base
        end
    end
    return nil
end

local function isSkinPartAllowed(partName)
    if partName == "ItemRoot" then
        return Config.SkinBlacklist.ItemRoot
    end
    return not Config.SkinBlacklist[partName]
end

local function applySkinToViewmodel(skinName)
    local tex = getSkinTexture(skinName)
    if not tex then return end
    local camModel = Workspace:FindFirstChild("Camera")
    if not camModel then return end
    local viewModel = camModel:FindFirstChild("ViewModel")
    if not viewModel then return end
    local item = viewModel:FindFirstChild("Item")
    if not item then return end
    for _, obj in ipairs(item:GetDescendants()) do
        if obj:IsA("MeshPart") then
            local partName = obj.Name
            if isSkinPartAllowed(partName) then
                for _, child in ipairs(obj:GetChildren()) do
                    if child:IsA("SurfaceAppearance") then
                        child:Destroy()
                    end
                end
                tex:Clone().Parent = obj
            end
        end
    end
end

local function applySkinToBoth(gunInstance, skin)
    if not gunInstance or not skin then return end
    local props = gunInstance:FindFirstChild("ItemProperties")
    if not props then
        props = Instance.new("Folder")
        props.Name = "ItemProperties"
        props.Parent = gunInstance
    end
    props:SetAttribute("Skin", skin)
    local playersFolder = ReplicatedStorage:FindFirstChild("Players")
    if playersFolder then
        local pf = playersFolder:FindFirstChild(LP.Name)
        local inv = pf and pf:FindFirstChild("Inventory")
        if inv then
            for _, obj in ipairs(inv:GetChildren()) do
                if obj:IsA("ObjectValue") and obj.Value and obj.Value.Name == gunInstance.Name then
                    obj:SetAttribute("Skin", skin)
                end
            end
        end
    end
    applySkinToViewmodel(skin)
end

local function applyAllSkins(skin)
    local itemsList = ReplicatedStorage:FindFirstChild("ItemsList")
    if not itemsList then return end
    for _, obj in ipairs(itemsList:GetChildren()) do
        if obj:IsA("Folder") or obj:IsA("Model") or obj:IsA("Tool") or obj:IsA("StringValue") then
            local props = obj:FindFirstChild("ItemProperties")
            if props then
                props:SetAttribute("Skin", skin)
            end
        end
    end
    applySkinToViewmodel(skin)
end

local function updateAllWeaponSkins()
    if not Config.SkinChanger then return end
    applyAllSkins(Config.Skin)
end

