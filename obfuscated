local Resources = {}

local function addResource(group, res)
    local list = Resources[group]
    if list then
        list[#list+1] = res
    else
        Resources[group] = {res}
    end
end

local function clearResources(group)
    local list = Resources[group]
    if not list then return end
    for _,res in ipairs(list) do
        pcall(function()
            local t = typeof(res)
            if t == "RBXScriptConnection" then
                if res.Connected then res:Disconnect() end
            elseif t == "Instance" then
                res:Destroy()
            elseif type(res) == "table" and res.Remove then
                res:Remove()
            elseif type(res) == "function" then
                res()
            end
        end)
    end
    Resources[group] = nil
end

