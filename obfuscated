local function setupCharacterESP(plr, char)
    if plr == LP then return end
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    local head = char:WaitForChild("Head", 5)
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not head or not humanoid then return end
    
    local hl
    if Config.UseHighlight then
        hl = Instance.new("Highlight")
        hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        hl.Parent = char
    end
    
    local nameTxt = NewText(TEXT_SIZE)
    local distTxt = NewText(TEXT_SIZE - 2)
    local healthTxt = NewText(TEXT_SIZE - 2)
    local friendTxt = NewText(TEXT_SIZE)
    friendTxt.Color = Color3.new(0,1,0)
    
    local healthBar = {}
    healthBar.bg = NewLine()
    healthBar.bg.Thickness = 4
    healthBar.bg.Color = Color3.new(0.2, 0.2, 0.2)
    healthBar.fg = NewLine()
    healthBar.fg.Thickness = 4
    
    local snapline = NewLine()
    snapline.Thickness = 1
    
    local lookLine = NewLine()
    lookLine.Thickness = 2
    lookLine.Color = Color3.fromRGB(255, 255, 0)
    
    local box = NewBox()
    local skeleton = NewSkeleton()
    local bodypartBoxes = {}
    
    local bodyParts = {"Head", "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
    for _ = 1, #bodyParts do
        bodypartBoxes[#bodypartBoxes + 1] = NewBox()
    end
    
    local tracer = NewLine()
    tracer.Thickness = Config.TracerThickness
    
    local drawings = {nameTxt, distTxt, healthTxt, friendTxt, tracer, healthBar.bg, healthBar.fg, snapline, lookLine}
    for _, l in ipairs(box) do
        drawings[#drawings + 1] = l
    end
    for _, l in ipairs(skeleton) do
        drawings[#drawings + 1] = l
    end
    for _, bpBox in ipairs(bodypartBoxes) do
        for _, l in ipairs(bpBox) do
            drawings[#drawings + 1] = l
        end
    end
    
    local function hide()
        for _,d in ipairs(drawings) do
            d.Visible = false
        end
        if hl then
            hl.Enabled = false
        end
    end
    
    humanoid.Died:Connect(hide)
    
    local lastWireframeState = false
    local wireframeHandles = {}
    
    addResource("ESP", RunService.RenderStepped:Connect(function()
        if not Config.ESP then
            hide()
            if lastWireframeState then
                for _, handle in pairs(wireframeHandles) do
                    if handle and handle.Parent then
                        handle:Destroy()
                    end
                end
                wireframeHandles = {}
                lastWireframeState = false
            end
            return
        end
        if not char:IsDescendantOf(Workspace) then
            hide()
            return
        end
        
        if Config.UseWireframe ~= lastWireframeState then
            if Config.UseWireframe then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        local handle = Instance.new("SelectionBox")
                        handle.Name = "WireframeHandle"
                        handle.Adornee = part
                        handle.LineThickness = 0.02
                        handle.Color3 = Config.WireframeColor
                        handle.Transparency = Config.WireframeTransparency
                        handle.Parent = part
                        wireframeHandles[part] = handle
                    end
                end
            else
                for _, handle in pairs(wireframeHandles) do
                    if handle and handle.Parent then
                        handle:Destroy()
                    end
                end
                wireframeHandles = {}
            end
            lastWireframeState = Config.UseWireframe
        elseif Config.UseWireframe then
            for part, handle in pairs(wireframeHandles) do
                if handle and handle.Parent then
                    handle.Color3 = Config.WireframeColor
                    handle.Transparency = Config.WireframeTransparency
                end
            end
        end
        
        local friend = isFriend(plr)
        local camPos = Cam.CFrame.Position
        local distStuds = (hrp.Position - camPos).Magnitude
        local distMeters = distStuds * 0.28
        
        local scrHRP, onScreen = Cam:WorldToViewportPoint(hrp.Position)
        local scrHead = Cam:WorldToViewportPoint(head.Position + Vector3.new(0,0.5,0))
        local scrFeet = Cam:WorldToViewportPoint(hrp.Position - Vector3.new(0,3,0))
        
        if not hl or not hl.Parent or not hl:IsA("Highlight") or hl.Parent ~= char then
            pcall(function()
                if hl then hl:Destroy() end
            end)
            hl = Instance.new("Highlight")
            hl.Name = "ESP_Highlight"
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            hl.Parent = char
        end
        
        if hl then
            local isLocked = false
            if lockedTarget and lockedTarget.Parent and lockedTarget.Parent == char then
                isLocked = true
            end
            
            local fillColor
            if friend then
                fillColor = Color3.new(0,1,0)
            elseif isLocked then
                fillColor = Color3.fromRGB(255,140,0)
            else
                fillColor = Config.BoxColor
            end
            
            if hl.FillColor ~= fillColor then
                hl.FillColor = fillColor
            end
            if hl.OutlineColor ~= Color3.new(1,1,1) then
                hl.OutlineColor = Color3.new(1,1,1)
            end
            local shouldEnable = Config.UseHighlight and onScreen
            if hl.Enabled ~= shouldEnable then
                hl.Enabled = shouldEnable
            end
        end
        
        nameTxt.Visible = Config.ShowName and onScreen and not friend
        if nameTxt.Visible then
            nameTxt.Text = plr.Name
            nameTxt.Position = Vector2.new(scrHead.X, scrHead.Y - TEXT_SIZE)
            nameTxt.Color = Config.TextColor
        end
        
        friendTxt.Visible = friend and onScreen
        if friendTxt.Visible then
            friendTxt.Text = Config.FriendLabel
            friendTxt.Position = Vector2.new(scrHead.X, scrHead.Y - TEXT_SIZE)
        end
        
        distTxt.Visible = Config.ShowDistance and onScreen
